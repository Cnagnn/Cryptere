# ============================================================
# Cryptere — Production .env Template
# ============================================================
# Copy to .env and fill in ALL placeholders before deploying.

APP_NAME=Cryptere
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# ---- 3 URL Utama (config/app.php derive subdomain otomatis) ----
APP_URL=https://cryptere.com
AUTH_URL=https://auth.cryptere.com
APP_HOME_URL=https://app.cryptere.com/dashboard

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---- Database ----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ---- Session ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.cryptere.com
SESSION_SECURE_COOKIE=true

# ---- Queue & Cache (shared hosting) ----
FILESYSTEM_DISK=local
COURSE_ASSET_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ---- Mail ----
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@cryptere.com"
MAIL_FROM_NAME="Cryptere"

# ---- Pusher (Broadcasting Production) ----
# Gunakan Pusher karena shared hosting tidak support WebSocket/Reverb.
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap1

BROADCAST_CONNECTION=pusher

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_CLUSTER="${PUSHER_APP_CLUSTER}"

# ---- OAuth: GitHub ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${AUTH_URL}/auth/github/callback"

# ---- OAuth: Google ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${AUTH_URL}/auth/google/callback"

# ---- Sentry ----
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

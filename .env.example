# Copy to .env and fill in ALL placeholders before deploying.

APP_NAME=Cryptere
APP_ENV=production
APP_KEY=base64:uDl9fpNiKO6v3IHeGs3VPKfc1wzPtw72hm8Y3t5REOk=
APP_DEBUG=false

# ---- 3 URL Utama (config/app.php derive subdomain otomatis) ----
APP_URL=https://cryptere.com
AUTH_URL=https://auth.cryptere.com
APP_HOME_URL=https://app.cryptere.com/dashboard

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---- Database ----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fkdzqxmc_cryptere
DB_USERNAME=fkdzqxmc_cryptere_user
DB_PASSWORD="bE#i~HYSrZ~Vl;-k"

# ---- Session ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.cryptere.com
SESSION_SECURE_COOKIE=true

# ---- Queue & Cache (shared hosting) ----
FILESYSTEM_DISK=local
COURSE_ASSET_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ---- Mail ----

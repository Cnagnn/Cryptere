APP_NAME=Cryptere
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# ---- Multi-Domain ----
# local:  leave all null (no subdomain routing)
# prod:   set to real domains (cryptere.com, auth.cryptere.com, app.cryptere.com)
PUBLIC_URL="${APP_URL}"
AUTH_URL="${APP_URL}"
APP_HOME_URL="${APP_URL}/dashboard"
PASSWORD_RESET_REDIRECT_URL="${AUTH_URL}/login"
PUBLIC_DOMAIN=null
AUTH_DOMAIN=null
APP_DOMAIN=null

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---- Database ----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cryptere_db
DB_USERNAME=root
DB_PASSWORD=

# ---- Session ----
# local: SESSION_DOMAIN=null, SESSION_SECURE_COOKIE=false
# prod:  SESSION_DOMAIN=.cryptere.com, SESSION_SECURE_COOKIE=true
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

# ---- Queue & Cache ----
# local: QUEUE_CONNECTION=database, BROADCAST_CONNECTION=reverb
# prod:  QUEUE_CONNECTION=sync, BROADCAST_CONNECTION=log
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
COURSE_ASSET_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# ---- Mail ----
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Reverb (WebSocket) ----
REVERB_APP_ID=cryptere-local
REVERB_APP_KEY=cryptere-key
REVERB_APP_SECRET=cryptere-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ---- OAuth: GitHub ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${AUTH_URL}/auth/github/callback"

# ---- OAuth: Google ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${AUTH_URL}/auth/google/callback"

# ---- Sentry ----
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

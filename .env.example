# ============================================================
# Cryptere — Production .env Template
# ============================================================
# Copy to .env on the production host and fill in ALL placeholders
# (values wrapped in <ANGLE_BRACKETS>) before deploying.
#
# For local development, this template is NOT meant to be used as-is —
# set APP_ENV=local, APP_URL=http://127.0.0.1:8000, MAIL_MAILER=log,
# BROADCAST_CONNECTION=reverb, and clear the production-only secrets.

APP_NAME=Cryptere
APP_ENV=production
APP_KEY=<RUN: php artisan key:generate>
APP_DEBUG=false

# ---- 3 URL Utama (config/app.php derive subdomain otomatis) ----
APP_URL=https://cryptere.com
AUTH_URL=https://auth.cryptere.com
APP_HOME_URL=https://app.cryptere.com/dashboard

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---- Database ----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=<CPANEL_DB_NAME>
DB_USERNAME=<CPANEL_DB_USER>
DB_PASSWORD="<CPANEL_DB_PASSWORD>"

# ---- Session ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.cryptere.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ---- Queue & Cache ----
# QUEUE_CONNECTION=database requires a cron job on the host:
#   * * * * * cd /path/to/project && php artisan queue:work --stop-when-empty --tries=3 --timeout=60 >> storage/logs/queue.log 2>&1
FILESYSTEM_DISK=local
COURSE_ASSET_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=file

# ---- Mail ----
MAIL_MAILER=smtp
MAIL_ENCRYPTION=ssl
MAIL_HOST=<SMTP_HOST>
MAIL_PORT=465
MAIL_USERNAME=<SMTP_USER>
MAIL_PASSWORD="<SMTP_PASSWORD>"
MAIL_FROM_ADDRESS=no-reply@cryptere.com
MAIL_FROM_NAME="${APP_NAME}"

# ---- Pusher (Broadcasting Production) ----
PUSHER_APP_ID=<PUSHER_APP_ID>
PUSHER_APP_KEY=<PUSHER_APP_KEY>
PUSHER_APP_SECRET=<PUSHER_APP_SECRET>
PUSHER_APP_CLUSTER=ap1

BROADCAST_CONNECTION=pusher

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_CLUSTER="${PUSHER_APP_CLUSTER}"

# ---- OAuth: GitHub ----
GITHUB_CLIENT_ID=<GITHUB_OAUTH_CLIENT_ID>
GITHUB_CLIENT_SECRET=<GITHUB_OAUTH_CLIENT_SECRET>
GITHUB_REDIRECT_URI="${AUTH_URL}/auth/github/callback"

# ---- OAuth: Google ----
GOOGLE_CLIENT_ID=<GOOGLE_OAUTH_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<GOOGLE_OAUTH_CLIENT_SECRET>
GOOGLE_REDIRECT_URI="${AUTH_URL}/auth/google/callback"

# ---- Sentry (optional — leave DSN empty to disable) ----
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

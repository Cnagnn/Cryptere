<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # ─────────────────────────────────────────────────────────────────
    # SECURITY — block accidental archive / backup / sensitive files
    # ─────────────────────────────────────────────────────────────────
    # Defense in depth: any developer who ever drops a .zip/.tar/.sql/.bak
    # under public/ leaks it. Match by extension so the .htaccess fail-closed
    # protects future mistakes too. CI also enforces "no archives in public"
    # via tests/Feature/Security/PublicArchivesAreBlockedTest.php.
    RewriteCond %{REQUEST_URI} \.(zip|tar|tar\.gz|tgz|tar\.bz2|tbz2|7z|rar|gz|bz2|sql|sqlite|sqlite3|db|sql\.gz|bak|backup|old|orig|swp|swo|log|env|ini|conf)$ [NC]
    RewriteRule ^ - [F,L]

    # Block dotfiles outright (.env, .git*, .htpasswd, .DS_Store, .vscode, etc.)
    RewriteCond %{REQUEST_URI} (^|/)\.(?!well-known/) [NC]
    RewriteRule ^ - [F,L]

    # ─────────────────────────────────────────────────────────────────
    # CANONICAL HOSTNAMES & SCHEMES
    # ─────────────────────────────────────────────────────────────────
    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # Keep one canonical public hostname for cache efficiency and SEO.
    RewriteCond %{HTTP_HOST} ^www\.cryptere\.com$ [NC]
    RewriteRule ^ https://cryptere.com%{REQUEST_URI} [R=301,L,NE]

    # Front controller is /, not /index.php — canonicalize for cache + SEO.
    RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
    RewriteRule ^index\.php(/.*)?$ /$1 [R=301,L,NE]

    # Canonical auth routes should move at the web server layer.
    RewriteCond %{HTTP_HOST} ^cryptere\.com$ [NC]
    RewriteCond %{REQUEST_METHOD} !^(GET|HEAD)$ [NC]
    RewriteRule ^(login|register|forgot-password|logout|reset-password(/.*)?)/?$ - [R=404,L]

    RewriteCond %{HTTP_HOST} ^cryptere\.com$ [NC]
    RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$ [NC]
    RewriteRule ^(login|register|forgot-password)/?$ https://auth.cryptere.com/$1 [R=301,L,NE]

    RewriteCond %{HTTP_HOST} ^cryptere\.com$ [NC]
    RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$ [NC]
    RewriteRule ^reset-password/(.*)$ https://auth.cryptere.com/reset-password/$1 [R=302,L,NE]

    # ─────────────────────────────────────────────────────────────────
    # LARAVEL FRONT CONTROLLER PIPELINE
    # ─────────────────────────────────────────────────────────────────
    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_headers.c>
    # Strip server-fingerprinting headers (defense in depth — middleware
    # also removes them at the app layer, but headers are easier to drop here).
    # `always` ensures the unset runs on EVERY response, including 4xx/5xx
    # error pages produced by LSWS itself before the request reaches PHP.
    Header always unset X-Powered-By
    Header always unset X-Turbo-Charged-By
    Header always unset X-AspNet-Version
    Header always unset X-AspNetMvc-Version
    Header always unset Server

    # ─────────────────────────────────────────────────────────────────
    # HSTS — defense in depth at web-server layer
    # ─────────────────────────────────────────────────────────────────
    # The SecurityHeaders middleware also emits HSTS, but that only fires
    # when the request actually reaches Laravel. If LSWS returns a 5xx
    # before PHP runs (overload, OPCache rebuild, etc.) the middleware
    # never executes and HSTS is missing — exposing first-time visitors
    # to SSL stripping. `always` here covers every HTTPS response.
    #
    # NOTE: HTTPS gate is done by `expr` because we serve plain HTTP only
    # for the 301 redirect at the top of the rewrite block; everything
    # else is HTTPS via Cloudflare.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" "expr=%{HTTPS} == 'on'"

    # ─────────────────────────────────────────────────────────────────
    # NEVER cache server errors at the LSWS / Cloudflare edge
    # ─────────────────────────────────────────────────────────────────
    # Without this, a transient 5xx (e.g. PHP-FPM hiccup during deploy)
    # gets pinned in LiteSpeed's edge cache for the lifetime of the
    # default Cache-Control set by the public landing-page middleware
    # (s-maxage=300). Result: the homepage stays "down" for 5 minutes
    # after the underlying issue is resolved. Force no-store on every
    # 5xx so the next request always re-hits the origin.
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" "expr=%{REQUEST_STATUS} >= 500"
    Header always set Pragma "no-cache" "expr=%{REQUEST_STATUS} >= 500"

    SetEnvIf Request_URI "^/build/assets/.+\.(css|js)$" vite_asset=1
    Header set Cache-Control "public, max-age=31536000, immutable" env=vite_asset
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
</IfModule>

APP_NAME=Cryptere
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# Localhost dev — single host on port 8000.
# AUTH_URL and APP_HOME_URL default to APP_URL when unset (see config/app.php),
# and Route::domain() constraints are auto-dropped on local hosts so /login,
# /register, /auth/{provider}/* all resolve on 127.0.0.1:8000.
# When deploying to cPanel with subdomains, fill these in .env.prod instead.
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cryptere
DB_USERNAME=cryptere
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_SECURE_COOKIE=false

FILESYSTEM_DISK=local
COURSE_ASSET_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

BROADCAST_CONNECTION=log

VITE_APP_NAME="${APP_NAME}"

# ---- OAuth: GitHub (https://github.com/settings/developers) ----
# For localhost dev, set the OAuth callback URL in the provider console to:
#   http://127.0.0.1:8000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- OAuth: Google (https://console.cloud.google.com) ----
# For localhost dev, set the OAuth callback URL in the provider console to:
#   http://127.0.0.1:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SENTRY_LARAVEL_DSN=
